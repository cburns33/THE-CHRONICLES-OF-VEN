# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# OpenAI API key — required for embeddings (provider: openai in config.yaml)
OPENAI_API_KEY=sk-...

# Optional: override the config.yaml document_id here instead
# GOOGLE_DOC_ID=your_doc_id_here

# Optional: set to "true" to enable verbose debug logging
DEBUG=false
